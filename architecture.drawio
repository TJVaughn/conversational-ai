<mxfile host="app.diagrams.net">
  <diagram name="Twilio AI CRM Architecture">
    <mxGraphModel dx="1422" dy="794" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="850">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- User -->
        <mxCell id="user" value="End User (SMS / Voice)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="40" y="300" width="160" height="60" as="geometry"/>
        </mxCell>

        <!-- Twilio -->
        <mxCell id="twilio" value="Twilio Platform&#xa;(SMS / Voice Webhooks)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="260" y="300" width="200" height="80" as="geometry"/>
        </mxCell>

        <!-- Python Server -->
        <mxCell id="server" value="Python Backend&#xa;(Flask / FastAPI)&#xa;Webhook Handler + Orchestration" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="520" y="280" width="240" height="100" as="geometry"/>
        </mxCell>

        <!-- AI Model -->
        <mxCell id="ai" value="AI Model API&#xa;(LLM / NLP Processing)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="840" y="200" width="220" height="80" as="geometry"/>
        </mxCell>

        <!-- CRM -->
        <mxCell id="crm" value="CRM System&#xa;(Salesforce / HubSpot / Custom)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="840" y="360" width="220" height="80" as="geometry"/>
        </mxCell>

        <!-- Database -->
        <mxCell id="db" value="Database&#xa;(User Data / Conversations)" style="shape=cylinder;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="520" y="420" width="200" height="80" as="geometry"/>
        </mxCell>

        <!-- Logging -->
        <mxCell id="logging" value="Logging / Monitoring&#xa;(CloudWatch / ELK)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0f0f0;strokeColor=#999999;" vertex="1" parent="1">
          <mxGeometry x="520" y="540" width="240" height="80" as="geometry"/>
        </mxCell>

        <!-- Edges -->
        <mxCell id="e1" value="SMS / Voice" style="endArrow=block;html=1;" edge="1" parent="1" source="user" target="twilio">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e2" value="Webhook Request" style="endArrow=block;html=1;" edge="1" parent="1" source="twilio" target="server">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e3" value="Process Input" style="endArrow=block;html=1;" edge="1" parent="1" source="server" target="ai">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e4" value="AI Response" style="endArrow=block;html=1;" edge="1" parent="1" source="ai" target="server">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e5" value="Read / Write Data" style="endArrow=block;html=1;" edge="1" parent="1" source="server" target="db">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e6" value="Sync Customer Data" style="endArrow=block;html=1;" edge="1" parent="1" source="server" target="crm">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e7" value="Logs / Metrics" style="endArrow=block;html=1;" edge="1" parent="1" source="server" target="logging">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e8" value="Send Response" style="endArrow=block;html=1;" edge="1" parent="1" source="server" target="twilio">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e9" value="Reply" style="endArrow=block;html=1;" edge="1" parent="1" source="twilio" target="user">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
